# OpenAI
OPENAI_API_KEY=sk-your-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# PostgreSQL (requires pgvector extension)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=multidocs
DATABASE_USER=multidocs
DATABASE_PASSWORD=change-me

# Telegram Bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_MODE=polling
# Webhook mode only (set TELEGRAM_MODE=webhook for production):
TELEGRAM_WEBHOOK_SECRET=generate-a-random-secret
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook/telegram

# MCP Server auth (Bearer token for /mcp endpoint)
MCP_API_KEY=generate-a-random-key

# Admin auth (Bearer token for /api/admin/* endpoints)
ADMIN_API_KEY=generate-a-random-key

# CORS (comma-separated origins, * for all)
ALLOWED_ORIGINS=*

# Agent settings
AGENT_TIMEOUT=120
RATE_LIMIT_RPM=30

# Documentation source directory
DOCS_DIR=docs

# Memory settings
CHAT_HISTORY_LIMIT=100
MEMORY_TOKEN_LIMIT=40000
MEMORY_MAX_FACTS=50

# App
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=False
